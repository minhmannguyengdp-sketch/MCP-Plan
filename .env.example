# Browser-visible configuration
NEXT_PUBLIC_APP_NAME=MCP-Plan

# Next.js server-only configuration
BACKEND_API_BASE_URL=http://127.0.0.1:3001
BACKEND_API_TOKEN=replace_with_at_least_32_random_characters
MCP_LEGACY_ACTOR_ID=service:mcp-plan:mcp-v1

# Transitional server-side read access. F0.5 will move remaining reads behind backend ports.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace_with_publishable_or_anon_key

# Optional MCP Report Agent capability
MCP_REPORT_AGENT_URL=
MCP_REPORT_AGENT_TOKEN=
