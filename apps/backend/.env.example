NODE_ENV=production
SERVICE_NAME=mcp-plan-backend
HOST=127.0.0.1
PORT=3001
LEGACY_INTERNAL_PORT=3002

INSTALLATION_ID=replace_with_installation_id
NPP_CODE=replace_with_npp_code
MCP_LEGACY_ACTOR_ID=service:replace_with_npp_code:mcp-v1
AUTH_MODE=proxy-service
BACKEND_API_TOKEN=replace_with_at_least_32_random_characters

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=server_only_replace_with_service_role_key
SUPABASE_ANON_KEY=replace_with_publishable_or_anon_key
DATABASE_URL=

CORS_ORIGINS=https://app.example.com
UPSTREAM_TIMEOUT_MS=65000
