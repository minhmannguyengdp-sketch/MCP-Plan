[Unit]
Description=MCP-Plan stale outlet media cleanup
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=root
Group=root
Environment=MCP_BACKEND_ENV_FILE=/var/www/mcp-plan-backend/.env
ExecStart=/var/www/mcp-plan-backend/ops/run-outlet-media-cleanup.sh
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadOnlyPaths=/var/www/mcp-plan-backend
