{
  "name": "mcp-plan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "audit:copy": "node scripts/audit-user-facing-copy.mjs",
    "audit:runtime-config": "node scripts/audit-runtime-hardcodes.mjs",
    "audit:direct-db-mutation": "node scripts/audit-direct-db-mutation-policy.mjs",
    "test:direct-db-mutation": "node --test test/audit-direct-db-mutations.test.mjs test/direct-db-retirement-subphase.test.mjs",
    "test:edge-retirement": "node --test test/a5-3-edge-retirement.test.mjs test/a5-3-no-legacy-edge-caller.test.mjs",
    "test:direct-rest-retirement": "node --test test/a5-4-1-dead-session-mutations.test.mjs test/a5-4-2-session-report-caller-audit.test.mjs test/a5-4-3-report-settings-caller-audit.test.mjs test/a5-4-4-field-check-market-report-caller-audit.test.mjs",
    "test:idempotency": "node --test test/a5-5-1-idempotency-caller-contract.test.mjs test/a5-5-2-session-action-caller-contract.test.mjs test/a5-5-2-session-action-runtime-smoke-contract.test.mjs test/route-active-session-ui-contract.test.mjs test/mcp-session-checkin-ui-contract.test.mjs test/f05-runtime-smoke-script.test.mjs",
    "test:production-hygiene": "node --test test/production-hygiene.test.mjs test/production-hygiene-no-fixture-leak.test.mjs",
    "test:pullmcp-deployer": "node --test test/pullmcp-deployer.test.mjs",
    "test:backend-api-auth": "node --test test/api-client-backend-auth.test.mjs test/production-tab-data-contract.test.mjs",
    "validate:runtime-config": "node scripts/validate-runtime-config.mjs",
    "smoke:f0-2-boundary": "node scripts/smoke-f0-2-boundary.mjs",
    "smoke:f05-runtime": "node test/runtime/smoke-f05-runtime-closure.mjs",
    "smoke:a5-5-2-session-actions": "node test/runtime/smoke-a5-5-2-session-actions.mjs",
    "test:foundation": "npm --prefix apps/backend test",
    "verify:copy": "npm run audit:copy && npm run typecheck",
    "verify:foundation": "npm run audit:runtime-config && npm run test:direct-db-mutation && npm run test:edge-retirement && npm run test:direct-rest-retirement && npm run test:idempotency && npm run test:production-hygiene && npm run audit:direct-db-mutation && npm run test:pullmcp-deployer && npm run test:backend-api-auth && npm run test:foundation && npm run typecheck && npm run test:theme-contract",
    "test:theme-contract": "node --test test/mcp-warm-theme-contract.test.mjs test/a5-5-2-session-action-live-caller-contract.test.mjs test/app-shell-expanded-menu-theme-contract.test.mjs"
  },
  "dependencies": {
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.6.2"
  }
}
