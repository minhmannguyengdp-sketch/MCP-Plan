{
  "name": "mcp-plan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "audit:copy": "node scripts/audit-user-facing-copy.mjs",
    "audit:runtime-config": "node scripts/audit-runtime-hardcodes.mjs",
    "validate:runtime-config": "node scripts/validate-runtime-config.mjs",
    "test:foundation": "npm --prefix apps/backend test",
    "verify:copy": "npm run audit:copy && npm run typecheck",
    "verify:foundation": "npm run audit:runtime-config && npm run test:foundation && npm run typecheck"
  },
  "dependencies": {
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.6.2"
  }
}
